#!/usr/bin/env bash
set -eu

trigger=".ghcid-trigger"
output=".ghcid-output"
timeout_s=60

launch() {
  # --ignore-loaded because otherwise ghcid dies if a file it was
  # watching is deleted
  exec ghcid \
    --ignore-loaded \
    --reload="$trigger" \
    --outputfile="$output" \
    --no-height-limit \
    --reverse-errors \
    "$@"
}

mtime_s () {
  stat -c %Y "$1" 2>/dev/null || stat -f %m "$1"
}

trigger_and_wait_for_output() {
  # ghcid does not allow sequentializing reload requests, so to
  # determine when the output file has been rewritten we track its
  # modification time.
  #
  # There is nonetheless a race condition should two ghcid-checks be run
  # concurrently.

  if [[ -f "$output" ]]; then
    before_output_s=$(mtime_s "$output")
  else
    before_output_s=$(date '+%s')
  fi

  # Wait for the current time in seconds to be greater than the
  # current timestamp of the output file.
  while (( $(date '+%s') <= before_output_s )); do
    sleep 0.1
  done

  date +%s >"$trigger"
  # The timestamp of the trigger file is therefore strictly greater
  # than the timestamp of the output file
  trigger_s=$(mtime_s "$trigger")

  deadline=$((SECONDS + timeout_s))
  while (( SECONDS < deadline )); do
    if [ -f "$output" ]; then
      output_s=$(mtime_s "$output")
      # When the output file has changed in response to our trigger
      # its timestamp will be at least the timestamp of the trigger
      # file
      if [ "$output_s" -ge "$trigger_s" ]; then
        return
      fi
    fi
    sleep 0.1
  done

  echo "ghcid-check: timed out waiting for $trigger; is ghcid running?" >&2
  exit 2
}

print_output() {
  if [ -f "$output" ]; then
    cat "$output"
  fi
}

status_from_errors() {
  if [[ ! -f "$output" ]]; then
    return 2
  fi

  if grep -q 'error:' "$output"; then
    return 1
  fi

  return 0
}

reload() {
  trigger_and_wait_for_output
  print_output
  status_from_errors
}

case "${1:-}" in
  --launch)
    shift
    launch "$@"
    ;;
  --reload)
    reload
    ;;
  *)
    printf 'usage: %s --launch <ghcid args...> | --reload\n' "$0" >&2
    exit 2
    ;;
esac
